{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Health Overview",
      "weight": "Bolder",
      "size": "Medium"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Latest Glucose",
              "isSubtle": true,
              "spacing": "None"
            },
            {
              "type": "TextBlock",
              "text": "${glucoseLevel} mg/dL",
              "size": "ExtraLarge",
              "color": "${statusColor}",
              "spacing": "None"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Status: ${statusText}",
      "isSubtle": true,
      "wrap": true
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Open App",
      "data": {
        "action": "openApp"
      }
    }
  ]
}
