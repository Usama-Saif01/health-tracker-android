{
  "name": "Personal Health Tracker",
  "short_name": "Health Track",
  "description": "Secure dashboard for personal health and fitness metrics.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0F172A",
  "theme_color": "#0F172A",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "id": "/?source=pwa",
  "categories": ["health", "medical", "fitness", "lifestyle"],
  "prefer_related_applications": false,
  "screenshots": [
    {
      "src": "/screenshot-desktop.jpg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "form_factor": "wide"
    },
    {
      "src": "/screenshot-mobile.jpg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "form_factor": "narrow"
    }
  ],
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "tabbed"],
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "iarc_rating_id": "e-rating",
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.app",
      "id": "com.example.app"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "url": "/",
      "icons": [{ "src": "/icon-192x192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/csv": [".csv"]
      }
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+health",
      "url": "/?url=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "note_taking": {
    "new_note_url": "/"
  },
  "widgets": [
    {
      "name": "Health Overview",
      "description": "Overview of your health metrics",
      "tag": "health-overview",
      "ms_ac_template": "/widgets/overview-template.json",
      "data": "/api/widgets/overview",
      "type": "application/json"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  }
}
